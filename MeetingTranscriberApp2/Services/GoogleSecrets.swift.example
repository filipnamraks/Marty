import Foundation

// Template for local Google OAuth credentials.
//
// Copy this file to GoogleSecrets.swift (same folder) and fill in your own
// values from Google Cloud Console → Credentials → OAuth client (Desktop app).
//
// GoogleSecrets.swift is .gitignored and must never be committed. This template
// (GoogleSecrets.swift.example) is committed so the project documents what is
// needed; its .example extension keeps it out of the build.
enum GoogleSecrets {
    static let clientID = "REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
    static let clientSecret = "REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET"
}
